<?xml version="1.0" encoding="utf-8"?>
<Window x:ConnectionId='1'
    x:Class="WipeOut.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WipeOut"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WipeOut Deep Cleaner">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title/Header Area -->
        <Grid Grid.Row="0" Margin="16,32,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE7B8;" FontSize="24" Foreground="{ThemeResource SystemAccentColor}" />
                <TextBlock Text="WipeOut" FontSize="24" FontWeight="SemiBold" />
                <ProgressRing x:ConnectionId='18'                                                      Width="20" Height="20" Margin="10,0,0,0" />
                <TextBlock x:ConnectionId='19'                                                       VerticalAlignment="Center" Margin="10,0,0,0" Opacity="0.6"/>
            </StackPanel>

            <TextBox x:ConnectionId='17' Grid.Column="1" 
                     PlaceholderText="Search applications..." 
                                                                                                            
                     VerticalAlignment="Center"/>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Apps List -->
            <ListView x:ConnectionId='2' x:Name="AppsListView"
                      Grid.Column="0"
                                                                                
                                                                                
                      SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            
                            <Image Grid.Column="0" Source="{Binding IconPath}" Width="40" Height="40" Stretch="Uniform" VerticalAlignment="Center" />
                            
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Publisher}" FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="{Binding FormattedSize}" FontSize="12" Opacity="0.5" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Details Panel (built in code-behind) -->
            <Border Grid.Column="1" 
                    Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    CornerRadius="8" 
                    Padding="20"
                    Margin="8,0,0,0">
                <StackPanel x:ConnectionId='3' x:Name="DetailsPanel" Spacing="12" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <FontIcon x:ConnectionId='4' x:Name="PlaceholderIcon" Glyph="&#xE716;" FontSize="48" Opacity="0.3" Margin="0,0,0,16" />
                    <TextBlock x:ConnectionId='5' x:Name="PlaceholderText" Text="Select an application to view details." TextWrapping="Wrap" TextAlignment="Center" Opacity="0.5" />
                    
                    <Image x:ConnectionId='6' x:Name="DetailIcon" Width="64" Height="64" Stretch="Uniform" HorizontalAlignment="Center" Visibility="Collapsed" />
                    <TextBlock x:ConnectionId='7' x:Name="DetailName" FontSize="20" FontWeight="Bold" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Visibility="Collapsed" />
                    <TextBlock x:ConnectionId='8' x:Name="DetailPublisher" FontSize="14" Opacity="0.8" HorizontalAlignment="Center" Visibility="Collapsed" />
                    
                    <MenuFlyoutSeparator x:ConnectionId='9' x:Name="DetailSeparator1" Margin="0,8" Visibility="Collapsed" />
                    
                    <TextBlock x:ConnectionId='10' x:Name="DetailVersion" FontSize="12" Opacity="0.6" Visibility="Collapsed" />
                    <TextBlock x:ConnectionId='11' x:Name="DetailType" FontSize="12" Opacity="0.6" Visibility="Collapsed" />
                    <TextBlock x:ConnectionId='12' x:Name="DetailDate" FontSize="12" Opacity="0.6" Visibility="Collapsed" />
                    <TextBlock x:ConnectionId='13' x:Name="DetailSize" FontSize="12" Opacity="0.6" Visibility="Collapsed" />
                    
                    <MenuFlyoutSeparator x:ConnectionId='14' x:Name="DetailSeparator2" Margin="0,16,0,8" Visibility="Collapsed" />
                    
                    <Button x:ConnectionId='15' x:Name="UninstallButton" Content="Uninstall &amp; Deep Clean" 
                            Style="{ThemeResource AccentButtonStyle}" 
                            HorizontalAlignment="Stretch" 
                                                         
                            Visibility="Collapsed" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

