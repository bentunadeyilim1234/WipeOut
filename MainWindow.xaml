<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WipeOut.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WipeOut"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WipeOut">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1000" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="NavView.PaneDisplayMode" Value="Left" />
                        <Setter Target="NavView.IsPaneOpen" Value="True" />
                        <Setter Target="DetailColumn.Width" Value="340" />
                        <Setter Target="DetailsBorder.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="MediumState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="720" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="NavView.PaneDisplayMode" Value="LeftCompact" />
                        <Setter Target="NavView.IsPaneOpen" Value="False" />
                        <Setter Target="DetailColumn.Width" Value="300" />
                        <Setter Target="DetailsBorder.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="NavView.PaneDisplayMode" Value="LeftMinimal" />
                        <Setter Target="NavView.IsPaneOpen" Value="False" />
                        <Setter Target="DetailColumn.Width" Value="0" />
                        <Setter Target="DetailsBorder.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <NavigationView x:Name="NavView"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        PaneDisplayMode="Left"
                        IsPaneOpen="True"
                        OpenPaneLength="220"
                        SelectionChanged="NavView_SelectionChanged"
                        PaneTitle="WipeOut">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="NavWin32" Tag="Win32" IsSelected="True">
                    <NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Desktop Apps" />
                            <InfoBadge x:Name="BadgeWin32" Style="{ThemeResource AttentionValueInfoBadgeStyle}" Value="0" Margin="8,0,0,0"/>
                        </StackPanel>
                    </NavigationViewItem.Content>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7F4;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="NavWindowsApps" Tag="WindowsApp">
                    <NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Windows Apps" />
                            <InfoBadge x:Name="BadgeUwp" Style="{ThemeResource AttentionValueInfoBadgeStyle}" Value="0" Margin="8,0,0,0"/>
                        </StackPanel>
                    </NavigationViewItem.Content>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE756;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Name="NavRefresh" Tag="Refresh">
                    <NavigationViewItem.Content>
                        <TextBlock Text="Refresh" />
                    </NavigationViewItem.Content>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE72C;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavAbout" Tag="About">
                    <NavigationViewItem.Content>
                        <TextBlock Text="About" />
                    </NavigationViewItem.Content>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <!-- Main Content Area -->
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header bar -->
                <Grid Grid.Row="0" Padding="24,16,24,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="300" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitle" Text="Desktop Apps" FontSize="22" FontWeight="SemiBold" />
                        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="18" Height="18" />
                        <TextBlock Text="{x:Bind ViewModel.LoadingMessage, Mode=OneWay}" VerticalAlignment="Center" Opacity="0.5" FontSize="13" />
                    </StackPanel>

                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="16" Padding="14,6" Margin="12,0" VerticalAlignment="Center">
                        <TextBlock x:Name="FilteredCountText" Text="0 apps" FontSize="12" Opacity="0.7" />
                    </Border>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="Sort by:" VerticalAlignment="Center" FontSize="12" Opacity="0.8"/>
                        <ComboBox SelectedItem="{x:Bind ViewModel.SortOption, Mode=TwoWay}" MinWidth="90" Height="32">
                            <x:String>Name</x:String>
                            <x:String>Size</x:String>
                            <x:String>Date</x:String>
                        </ComboBox>
                        <ToggleButton IsChecked="{x:Bind ViewModel.SortDescending, Mode=TwoWay}" Height="32" Content="Desc" />
                    </StackPanel>

                    <AutoSuggestBox Grid.Column="3"
                                    x:Name="SearchBox"
                                    PlaceholderText="Search apps..."
                                    QueryIcon="Find"
                                    TextChanged="SearchBox_TextChanged"
                                    VerticalAlignment="Center"/>
                </Grid>

                <!-- App List + Details Split -->
                <Grid Grid.Row="1" Padding="24,0,24,24" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="280" />
                        <ColumnDefinition x:Name="DetailColumn" Width="340" />
                    </Grid.ColumnDefinitions>

                    <!-- App List -->
                    <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <ListView x:Name="AppsListView"
                                  ItemsSource="{x:Bind ViewModel.FilteredApps, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedApp, Mode=TwoWay}"
                                  SelectionMode="Single"
                                  Padding="4">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Margin" Value="2,1" />
                                    <Setter Property="CornerRadius" Value="6" />
                                    <Setter Property="Padding" Value="8,6" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="6,4" ColumnSpacing="12" Height="52">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon with clipping to keep uniform square -->
                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                            <Border CornerRadius="8">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding IconPath}" Stretch="UniformToFill" />
                                                </Border.Background>
                                            </Border>
                                        </Border>

                                        <!-- Name + Publisher -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Publisher}" FontSize="11" Opacity="0.55" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <!-- Size -->
                                        <TextBlock Grid.Column="2" Text="{Binding FormattedSize}" FontSize="11" Opacity="0.4" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>

                    <!-- Details Panel -->
                    <Border x:Name="DetailsBorder" Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="24">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="DetailsPanel" Spacing="10">

                                <!-- Placeholder -->
                                <StackPanel x:Name="PlaceholderPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" Margin="0,80,0,0">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="48" Opacity="0.2" HorizontalAlignment="Center" />
                                    <TextBlock Text="Select an application" FontSize="14" Opacity="0.4" TextAlignment="Center" />
                                    <TextBlock Text="Click on any app to view its details and uninstall options." FontSize="12" Opacity="0.3" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="220" />
                                </StackPanel>

                                <!-- Detail content -->
                                <StackPanel x:Name="DetailContent" Visibility="Collapsed" Spacing="12">
                                    <StackPanel HorizontalAlignment="Center" Spacing="10" Margin="0,8,0,0">
                                        <!-- Large icon with clipping -->
                                        <Border Width="72" Height="72" CornerRadius="16" Background="{ThemeResource SubtleFillColorSecondaryBrush}" HorizontalAlignment="Center">
                                            <Border CornerRadius="16">
                                                <Border.Background>
                                                    <ImageBrush x:Name="DetailIconBrush" Stretch="UniformToFill" />
                                                </Border.Background>
                                            </Border>
                                        </Border>
                                        <TextBlock x:Name="DetailName" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" MaxWidth="280" />
                                        <TextBlock x:Name="DetailPublisher" FontSize="13" Opacity="0.6" TextAlignment="Center" HorizontalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Type badge -->
                                    <Border x:Name="DetailTypeBadge" CornerRadius="12" Padding="12,4" HorizontalAlignment="Center" Margin="0,4,0,0">
                                        <TextBlock x:Name="DetailTypeBadgeText" FontSize="11" FontWeight="SemiBold" />
                                    </Border>

                                    <MenuFlyoutSeparator Margin="0,8" />

                                    <!-- Info grid -->
                                    <Grid RowSpacing="10" ColumnSpacing="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Version" FontSize="12" Opacity="0.45" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DetailVersion" FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Right"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Installed" FontSize="12" Opacity="0.45" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DetailDate" FontSize="12" HorizontalAlignment="Right"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Size" FontSize="12" Opacity="0.45" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DetailSize" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <MenuFlyoutSeparator Margin="0,8" />

                                    <!-- Uninstall button -->
                                    <Button x:Name="UninstallButton"
                                            HorizontalAlignment="Stretch"
                                            Click="UninstallButton_Click"
                                            Height="40"
                                            CornerRadius="6"
                                            Style="{ThemeResource AccentButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                            <TextBlock Text="Uninstall &amp; Deep Clean" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
